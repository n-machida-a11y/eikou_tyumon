/** 直近の発注ヘッダ要約（複製ピッカー用）。limit件、新しい順。 */
function getRecentOrders(limit) {
  const lim = limit || 50;
  const sh = getOrdersSheet_();
  if (!sh || sh.getLastRow() < 2) return [];
  const data = sh.getDataRange().getValues();
  const col = headerIndex_(data[0]);
  // orderNumberごとに集約しつつ、最新行 (createdAt の降順) を採用
  const byOrder = {};
  for (let i = 1; i < data.length; i++) {
    const row = data[i];
    const n = String(row[col.orderNumber]);
    if (!byOrder[n]) byOrder[n] = { orderNumber: n, orderDate: formatCellDate_(row[col.orderDate]), supplier: row[col.supplier], person: row[col.person], usage: row[col.usage], itemCount: 0, createdAt: row[col.createdAt], status: row[col.status] };
    byOrder[n].itemCount++;
  }
  const arr = Object.keys(byOrder).map(function(k) { return byOrder[k]; });
  arr.sort(function(a, b) {
    const ta = a.createdAt instanceof Date ? a.createdAt.getTime() : 0;
    const tb = b.createdAt instanceof Date ? b.createdAt.getTime() : 0;
    return tb - ta;
  });
  return arr.slice(0, lim).map(function(o) { delete o.createdAt; return o; });
}


// ■ ダッシュボード ============================================

function getDashboard() {
  const sh = getOrdersSheet_();
  if (!sh || sh.getLastRow() < 2) {
    return { overdue: { count: 0 }, thisWeek: { count: 0 }, todayFinish: { count: 0 }, projects: [] };
  }
  const data = sh.getDataRange().getValues();
  const col = headerIndex_(data[0]);
  const today = formatDate_(new Date());
  const wkEnd = formatDate_(new Date(Date.now() + 7 * 86400000));
  let overdue = 0, thisWeek = 0, todayFinish = 0;
  const projects = {};
  for (let i = 1; i < data.length; i++) {
    const row = data[i];
    const status = row[col.status];
    if (status === STATUS.CANCELED) continue;
    const planned = formatCellDate_(row[col.plannedDelivery]);
    const finish = formatCellDate_(row[col.finishDate]);
    if (planned && planned < today && (status === STATUS.ORDERED || status === STATUS.CONFIRMED)) overdue++;
    if (planned && planned >= today && planned <= wkEnd && status !== STATUS.DONE) thisWeek++;
    if (finish === today) todayFinish++;
    const usage = String(row[col.usage] || '').trim();
    if (usage && status !== STATUS.DONE) {
      if (!projects[usage]) projects[usage] = { usage: usage, total: 0, byStatus: {} };
      projects[usage].total++;
      projects[usage].byStatus[status] = (projects[usage].byStatus[status] || 0) + 1;
    }
  }
  return {
    overdue: { count: overdue },
    thisWeek: { count: thisWeek },
    todayFinish: { count: todayFinish },
    projects: Object.keys(projects).map(function(k) { return projects[k]; })
      .sort(function(a, b) { return b.total - a.total; }).slice(0, 10)
  };
}


