    orderNumber: header.indexOf('発注番号'),
    lineNumber: header.indexOf('行番号'),
    orderDate: header.indexOf('発注日'),
    supplier: header.indexOf('仕入先名'),
    deliveryDate: header.indexOf('納期'),
    person: header.indexOf('担当者'),
    name: header.indexOf('品名'),
    quantity: header.indexOf('数量'),
    unitPrice: header.indexOf('単価'),
    amount: header.indexOf('金額'),
    note: header.indexOf('備考'),
    usage: header.indexOf('用途'),
    internalMemo: header.indexOf('社内メモ'),
    plannedDelivery: header.indexOf('納品予定日'),
    arrivalDate: header.indexOf('入荷日'),
    finishDate: header.indexOf('仕上日'),
    status: header.indexOf('ステータス'),
    createdAt: header.indexOf('作成日時'),
    updatedAt: header.indexOf('更新日時')
  };
}

function rowToOrderItem_(row, col) {
  return {
    orderNumber: row[col.orderNumber],
    lineNumber: row[col.lineNumber],
    orderDate: formatCellDate_(row[col.orderDate]),
    supplier: row[col.supplier],
    deliveryDate: row[col.deliveryDate],
    person: row[col.person],
    name: row[col.name],
    quantity: row[col.quantity],
    unitPrice: row[col.unitPrice],
    amount: row[col.amount],
    note: row[col.note],
    usage: row[col.usage],
    internalMemo: row[col.internalMemo],
    plannedDelivery: formatCellDate_(row[col.plannedDelivery]),
    arrivalDate: formatCellDate_(row[col.arrivalDate]),
    finishDate: formatCellDate_(row[col.finishDate]),
    status: row[col.status]
  };
}

function formatCellDate_(v) {
  if (v === '' || v === null || v === undefined) return '';
  if (Object.prototype.toString.call(v) === '[object Date]') {
    return Utilities.formatDate(v, 'Asia/Tokyo', 'yyyy-MM-dd');
  }
  return String(v);
}

function formatYymmdd_(date) { return Utilities.formatDate(date, 'Asia/Tokyo', 'yyMMdd'); }
function formatDate_(date)   { return Utilities.formatDate(date, 'Asia/Tokyo', 'yyyy-MM-dd'); }
function pad3_(n)            { return ('000' + n).slice(-3); }
