}

/**
 * 日計表シートで会社名が空の行に直前の会社名を前方埋めする。
 * 履歴.xlsx を直接コピー＆ペーストした場合の補正用。importLegacyFromRawSheet 経由なら不要。
 */
function normalizeLegacy() {
  const sh = getLegacySheet_();
  if (!sh || sh.getLastRow() < 2) return;
  const range = sh.getRange(2, 1, sh.getLastRow() - 1, 1);
  const values = range.getValues();
  let carry = '';
  for (let i = 0; i < values.length; i++) {
    const v = String(values[i][0] || '').trim();
    if (v) carry = v;
    else values[i][0] = carry;
  }
  range.setValues(values);
  invalidateSearchCache_();
}


// ■ 納品日登録 ================================================

function updateDelivery(payload) {
  const p = payload || {};
  if (!p.orderNumber) throw new Error('発注番号が指定されていません');
  const sh = getOrdersSheet_();
  const data = sh.getDataRange().getValues();
  const col = headerIndex_(data[0]);
  const targetLine = p.lineNumber ? Number(p.lineNumber) : null;
  const rowsUpdated = [];
  const changes = [];
  const now = new Date();
  for (let i = 1; i < data.length; i++) {
    if (String(data[i][col.orderNumber]) !== String(p.orderNumber)) continue;
    if (targetLine && Number(data[i][col.lineNumber]) !== targetLine) continue;
    const row = data[i];
    const before = { plannedDelivery: row[col.plannedDelivery], arrivalDate: row[col.arrivalDate], finishDate: row[col.finishDate], status: row[col.status] };
    if (p.plannedDelivery !== undefined) row[col.plannedDelivery] = p.plannedDelivery;
    if (p.arrivalDate !== undefined) row[col.arrivalDate] = p.arrivalDate;
    if (p.finishDate !== undefined) row[col.finishDate] = p.finishDate;
    row[col.status] = nextStatus_(p, row[col.status]);
    row[col.updatedAt] = now;
    sh.getRange(i + 1, 1, 1, row.length).setValues([row]);
    rowsUpdated.push(row[col.lineNumber]);
    changes.push({ line: row[col.lineNumber], before: before, after: { plannedDelivery: row[col.plannedDelivery], arrivalDate: row[col.arrivalDate], finishDate: row[col.finishDate], status: row[col.status] } });
  }
  if (rowsUpdated.length === 0) throw new Error('該当行が見つかりません');
  changes.forEach(function(c) {
    ['plannedDelivery', 'arrivalDate', 'finishDate', 'status'].forEach(function(k) {
      if (formatCellDate_(c.before[k]) !== formatCellDate_(c.after[k])) {
        const labels = { plannedDelivery: '納品予定日', arrivalDate: '入荷日', finishDate: '仕上日', status: 'ステータス' };
        appendAuditLog_(AUDIT_ACTION.DELIVERY, p.orderNumber, c.line, labels[k], formatCellDate_(c.before[k]), formatCellDate_(c.after[k]), '');
      }
    });
  });
  invalidateSearchCache_();
  return { updated: rowsUpdated.length };
}

function nextStatus_(p, current) {
  if (p.status) return p.status;
  if (p.finishDate) return STATUS.DONE;
  if (p.arrivalDate) return STATUS.ARRIVED;
  if (p.plannedDelivery) return STATUS.CONFIRMED;
  return current;
}


