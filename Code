}

/**
 * 新規の仕入先名/担当者名/品名をマスタへ追加する。
 * payload = { suppliers: ['ABC'], persons: ['山田'], items: ['新部品'] }
 * 既存と重複するものはスキップ。
 */
function addToMasters(payload) {
  const p = payload || {};
  const result = { suppliers: 0, persons: 0, items: 0 };

  const supSh = getSuppliersSheet_();
  if (supSh && p.suppliers && p.suppliers.length) {
    const existing = readSuppliers_().reduce(function(s, x) { s[x.name] = true; return s; }, {});
    const fresh = p.suppliers.filter(function(n) { return n && !existing[n]; });
    if (fresh.length) {
      const rows = fresh.map(function(n) { return [n, '御中', '', '', '', '', '']; });
      supSh.getRange(supSh.getLastRow() + 1, 1, rows.length, SUPPLIER_HEADER.length).setValues(rows);
      result.suppliers = rows.length;
    }
  }
  const pSh = getPersonsSheet_();
  if (pSh && p.persons && p.persons.length) {
    const existing = readPersons_().reduce(function(s, x) { s[x.name] = true; return s; }, {});
    const fresh = p.persons.filter(function(n) { return n && !existing[n]; });
    if (fresh.length) {
      const rows = fresh.map(function(n) { return [n, '', '']; });
      pSh.getRange(pSh.getLastRow() + 1, 1, rows.length, PERSON_HEADER.length).setValues(rows);
      result.persons = rows.length;
    }
  }
  const iSh = getItemsSheet_();
  if (iSh && p.items && p.items.length) {
    const existing = readItems_().reduce(function(s, x) { s[x.name] = true; return s; }, {});
    const fresh = [];
    const seen = {};
    p.items.forEach(function(n) { if (n && !existing[n] && !seen[n]) { seen[n] = true; fresh.push(n); } });
    if (fresh.length) {
      const rows = fresh.map(function(n) { return [n, '', '', '', '']; });
      iSh.getRange(iSh.getLastRow() + 1, 1, rows.length, ITEM_HEADER.length).setValues(rows);
      result.items = rows.length;
    }
  }
  return result;
}


