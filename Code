// ■ 注文の保存 ================================================

function saveOrder(header, items) {
  if (!items || items.length === 0) throw new Error('明細が空です');
  const lock = LockService.getScriptLock();
  lock.waitLock(10000);
  try {
    const now = new Date();
    const orderNumber = header.orderNumber && header.orderNumber.trim()
      ? header.orderNumber.trim()
      : generateOrderNumber_(now);
    const orderDate = header.orderDate || formatDate_(now);
    const rows = items.map(function(item, idx) {
      return [
        orderNumber, idx + 1, orderDate,
        header.supplier || '', header.deliveryDate || '', header.person || '',
        item.name || '', item.quantity || '', item.unitPrice || '', item.amount || '', item.note || '',
        header.usage || '', header.internalMemo || '',
        '', '', '', STATUS.ORDERED,
        now, now
      ];
    });
    const sh = getOrdersSheet_();
    sh.getRange(sh.getLastRow() + 1, 1, rows.length, ORDERS_HEADER.length).setValues(rows);
    appendAuditLog_(AUDIT_ACTION.CREATE, orderNumber, '', '',
      '', items.length + '明細', header.supplier || '');
    invalidateSearchCache_();
    return { orderNumber: orderNumber, rowCount: rows.length };
  } finally {
    lock.releaseLock();
  }
}

/**
 * 既存注文を編集する。orderNumber 行を全削除→新内容で再書込。
 * 既存の作成日時・採番は維持、変更点を操作ログに記録。
 */
function updateOrder(orderNumber, header, items) {
  if (!orderNumber) throw new Error('発注番号が指定されていません');
  if (!items || items.length === 0) throw new Error('明細が空です');
  const lock = LockService.getScriptLock();
  lock.waitLock(10000);
  try {
    const sh = getOrdersSheet_();
    const data = sh.getDataRange().getValues();
    const col = headerIndex_(data[0]);
    const targetRows = [];
    for (let i = 1; i < data.length; i++) {
      if (String(data[i][col.orderNumber]) === String(orderNumber)) targetRows.push(i);
    }
    if (targetRows.length === 0) throw new Error('対象の発注番号が見つかりません: ' + orderNumber);

    const oldFirst = data[targetRows[0]];
    const createdAt = oldFirst[col.createdAt] || new Date();
    const oldOrderDate = formatCellDate_(oldFirst[col.orderDate]) || formatDate_(new Date());
    const oldSupplier = oldFirst[col.supplier];
    const oldDeliveryDate = oldFirst[col.deliveryDate];
    const oldPerson = oldFirst[col.person];
    const oldUsage = oldFirst[col.usage];
    const oldMemo = oldFirst[col.internalMemo];
    // 既存の納品予定日／入荷日／仕上日／ステータスは行番号で引き継ぐ
    const carryByLine = {};
    targetRows.forEach(function(i) {
      const row = data[i];
      carryByLine[Number(row[col.lineNumber])] = {
        plannedDelivery: row[col.plannedDelivery],
        arrivalDate: row[col.arrivalDate],
        finishDate: row[col.finishDate],
        status: row[col.status]
      };
    });

    const now = new Date();
    const supplier = header.supplier !== undefined ? header.supplier : oldSupplier;
    const deliveryDate = header.deliveryDate !== undefined ? header.deliveryDate : oldDeliveryDate;
    const person = header.person !== undefined ? header.person : oldPerson;
    const usage = header.usage !== undefined ? header.usage : oldUsage;
    const memo = header.internalMemo !== undefined ? header.internalMemo : oldMemo;
    const orderDate = header.orderDate || oldOrderDate;

    const newRows = items.map(function(item, idx) {
      const lineNum = idx + 1;
      const carry = carryByLine[lineNum] || { plannedDelivery: '', arrivalDate: '', finishDate: '', status: STATUS.ORDERED };
      return [
        orderNumber, lineNum, orderDate,
        supplier, deliveryDate, person,
        item.name || '', item.quantity || '', item.unitPrice || '', item.amount || '', item.note || '',
        usage, memo,
        carry.plannedDelivery, carry.arrivalDate, carry.finishDate, carry.status,
        createdAt, now
      ];
    });

    // 既存行を下から削除
    targetRows.slice().reverse().forEach(function(i) { sh.deleteRow(i + 1); });
    sh.getRange(sh.getLastRow() + 1, 1, newRows.length, ORDERS_HEADER.length).setValues(newRows);

    // 変更ログ
    if (oldSupplier !== supplier) appendAuditLog_(AUDIT_ACTION.UPDATE, orderNumber, '', '仕入先名', oldSupplier, supplier, '');
    if (oldDeliveryDate !== deliveryDate) appendAuditLog_(AUDIT_ACTION.UPDATE, orderNumber, '', '納期', oldDeliveryDate, deliveryDate, '');
    if (oldPerson !== person) appendAuditLog_(AUDIT_ACTION.UPDATE, orderNumber, '', '担当者', oldPerson, person, '');
    if (oldUsage !== usage) appendAuditLog_(AUDIT_ACTION.UPDATE, orderNumber, '', '用途', oldUsage, usage, '');
    if (oldMemo !== memo) appendAuditLog_(AUDIT_ACTION.UPDATE, orderNumber, '', '社内メモ', oldMemo, memo, '');
    appendAuditLog_(AUDIT_ACTION.UPDATE, orderNumber, '', '明細', targetRows.length + '行', newRows.length + '行', '内容更新');

    invalidateSearchCache_();
    return { orderNumber: orderNumber, rowCount: newRows.length };
  } finally {
    lock.releaseLock();
  }
}

/** 発注を取消（全行のステータスを「取消」に） */
function cancelOrder(orderNumber, reason) {
  return setOrderStatus_(orderNumber, STATUS.CANCELED, AUDIT_ACTION.CANCEL, reason || '');
}

/** 取消を解除（全行のステータスを「発注済」に戻す） */
function restoreOrder(orderNumber) {
  return setOrderStatus_(orderNumber, STATUS.ORDERED, AUDIT_ACTION.RESTORE, '');
}

function setOrderStatus_(orderNumber, newStatus, action, note) {
  if (!orderNumber) throw new Error('発注番号が指定されていません');
  const sh = getOrdersSheet_();
  const data = sh.getDataRange().getValues();
  const col = headerIndex_(data[0]);
  const now = new Date();
  let updated = 0;
  let oldStatus = '';
  for (let i = 1; i < data.length; i++) {
    if (String(data[i][col.orderNumber]) !== String(orderNumber)) continue;
    if (!oldStatus) oldStatus = data[i][col.status];
    const row = data[i].slice();
    row[col.status] = newStatus;
    row[col.updatedAt] = now;
    sh.getRange(i + 1, 1, 1, row.length).setValues([row]);
    updated++;
  }
  if (updated === 0) throw new Error('対象の発注番号が見つかりません: ' + orderNumber);
  appendAuditLog_(action, orderNumber, '', 'ステータス', oldStatus, newStatus, note);
  invalidateSearchCache_();
  return { updated: updated };
}

function generateOrderNumber_(date) {
  const yymmdd = formatYymmdd_(date);
  const sh = getCountersSheet_();
  const data = sh.getDataRange().getValues();
  for (let i = 1; i < data.length; i++) {
    if (String(data[i][0]) === yymmdd) {
      const next = Number(data[i][1]) + 1;
      sh.getRange(i + 1, 2).setValue(next);
      return yymmdd + pad3_(next);
    }
  }
  sh.appendRow([yymmdd, 1]);
  return yymmdd + '001';
}


// ■ 注文の取得 ================================================

function getOrder(orderNumber) {
  const sh = getOrdersSheet_();
  const data = sh.getDataRange().getValues();
  const col = headerIndex_(data[0]);
  const rows = [];
  for (let i = 1; i < data.length; i++) {
    if (String(data[i][col.orderNumber]) === String(orderNumber)) {
      rows.push(rowToOrderItem_(data[i], col));
    }
  }
  if (rows.length === 0) return null;
  rows.sort(function(a, b) { return a.lineNumber - b.lineNumber; });
  const h = rows[0];
  return {
    orderNumber: h.orderNumber, orderDate: h.orderDate,
    supplier: h.supplier, deliveryDate: h.deliveryDate, person: h.person,
    usage: h.usage, internalMemo: h.internalMemo,
    items: rows
  };
}


// ■ 検索 =====================================================

function searchAll(query) {
  const q = normalizeQuery_(query);
  const cache = CacheService.getScriptCache();
  const cacheKey = SEARCH_CACHE_QUERY_PREFIX + simpleHash_(JSON.stringify(q));
  const cached = cache.get(cacheKey);
  if (cached) {
    try { return JSON.parse(cached); } catch (e) { /* fallthrough */ }
  }

  const text = q.text;
  const source = q.source;
  const rowsBase = [];

  if (source === 'orders' || source === 'both') {
    Array.prototype.push.apply(rowsBase, loadOrdersCached_());
  }
  if (source === 'legacy' || source === 'both') {
    if (text) {
      Array.prototype.push.apply(rowsBase, searchLegacyByText_(text, SEARCH_RESULT_LIMIT * 2));
    } else {
      Array.prototype.push.apply(rowsBase, readLegacyForSearch_());
    }
  }

  const hits = [];
  for (let i = 0; i < rowsBase.length; i++) {
    const r = rowsBase[i];
    if (text && !matchesText_(r, text)) continue;
    if (q.supplier && String(r.supplier).indexOf(q.supplier) < 0) continue;
    if (q.status && r.status !== q.status) continue;
    if (q.usage && String(r.usage || '').indexOf(q.usage) < 0) continue;
    if (!withinRange_(r, q.dateFrom, q.dateTo)) continue;
    if (q.preset && !matchesPreset_(r, q.preset)) continue;
    hits.push(r);
    if (hits.length >= SEARCH_RESULT_LIMIT) break;
  }
  const result = { total: hits.length, limit: SEARCH_RESULT_LIMIT, rows: hits };
  try {
    const json = JSON.stringify(result);
    if (json.length < 95000) {
      cache.put(cacheKey, json, SEARCH_CACHE_TTL);
      pushQueryCacheKey_(cacheKey);
    }
  } catch (e) { /* skip */ }
  return result;
}

function normalizeQuery_(query) {
  const q = query || {};
  return {
    text: (q.text || '').trim(),
    supplier: (q.supplier || '').trim(),
    status: (q.status || '').trim(),
    usage: (q.usage || '').trim(),
    dateFrom: q.dateFrom || '',
    dateTo: q.dateTo || '',
    source: q.source || 'both',
    preset: q.preset || ''
  };
}

function matchesPreset_(r, preset) {
  if (preset === 'overdue') {
    const today = formatDate_(new Date());
    return r.source === 'orders' && r.plannedDelivery && r.plannedDelivery < today &&
      (r.status === STATUS.ORDERED || r.status === STATUS.CONFIRMED);
  }
  if (preset === 'this_week') {
    const today = new Date();
    const todayStr = formatDate_(today);
    const wkEnd = new Date(today.getTime() + 7 * 86400000);
    const wkEndStr = formatDate_(wkEnd);
    return r.source === 'orders' && r.plannedDelivery && r.plannedDelivery >= todayStr && r.plannedDelivery <= wkEndStr &&
      r.status !== STATUS.DONE && r.status !== STATUS.CANCELED;
  }
  if (preset === 'today_finish') {
    const today = formatDate_(new Date());
    return r.source === 'orders' && r.finishDate === today;
  }
  return true;
}

/** legacyシートを TextFinder で前段絞り込みして返す。textは必須。 */
function searchLegacyByText_(text, hardLimit) {
  const sh = getLegacySheet_();
  if (!sh || sh.getLastRow() < 2) return [];
  const finder = sh.createTextFinder(text).matchEntireCell(false).matchCase(false);
  const matches = finder.findAll();
  if (matches.length === 0) return [];
  const rowSet = {};
  for (let i = 0; i < matches.length; i++) {
    const r = matches[i].getRow();
    if (r === 1) continue;
    rowSet[r] = true;
    if (Object.keys(rowSet).length >= hardLimit) break;
  }
  const rowNums = Object.keys(rowSet).map(Number).sort(function(a, b) { return a - b; });
  if (rowNums.length === 0) return [];
  // ヒット行のみ取得（連続性は無視、1行ずつ getValues すると遅いので一括レンジで取って後で絞る）
  const minR = rowNums[0];
  const maxR = rowNums[rowNums.length - 1];
  const block = sh.getRange(minR, 1, maxR - minR + 1, LEGACY_HEADER.length).getValues();
  const header = sh.getRange(1, 1, 1, LEGACY_HEADER.length).getValues()[0];
  const idx = {
    company: header.indexOf('会社名'),
    name: header.indexOf('品名'),
    quantity: header.indexOf('数量'),
    arrival: header.indexOf('入荷日'),
    finish: header.indexOf('仕上日'),
    note: header.indexOf('備考')
  };
  const out = [];
  for (let k = 0; k < rowNums.length; k++) {
    const r = rowNums[k] - minR;
    const row = block[r];
    out.push({
      source: 'legacy',
      orderNumber: '',
      supplier: row[idx.company],
      name: row[idx.name],
      quantity: row[idx.quantity],
      note: row[idx.note],
      arrivalDate: formatCellDate_(row[idx.arrival]),
      finishDate: formatCellDate_(row[idx.finish]),
      status: ''
    });
  }
  return out;
}

function pushQueryCacheKey_(key) {
  const cache = CacheService.getScriptCache();
  const idx = cache.get(SEARCH_CACHE_QUERY_INDEX_KEY);
  let arr = [];
  if (idx) try { arr = JSON.parse(idx); } catch (e) { arr = []; }
  if (arr.indexOf(key) < 0) arr.push(key);
  if (arr.length > 200) arr = arr.slice(-200);
  cache.put(SEARCH_CACHE_QUERY_INDEX_KEY, JSON.stringify(arr), SEARCH_CACHE_TTL);
}

function clearQueryCache_() {
  const cache = CacheService.getScriptCache();
  const idx = cache.get(SEARCH_CACHE_QUERY_INDEX_KEY);
  if (!idx) return;
  try {
    const arr = JSON.parse(idx);
    if (arr.length) cache.removeAll(arr);
  } catch (e) { /* skip */ }
  cache.remove(SEARCH_CACHE_QUERY_INDEX_KEY);
}

function simpleHash_(str) {
  let h = 0;
  for (let i = 0; i < str.length; i++) {
    h = ((h << 5) - h) + str.charCodeAt(i);
    h |= 0;
  }
  return h.toString(36);
}

function matchesText_(r, text) {
  const needle = text.toLowerCase();
  const hay = [r.orderNumber, r.supplier, r.name, r.note, r.usage, r.internalMemo]
    .map(function(x) { return String(x || '').toLowerCase(); }).join(' ');
  return hay.indexOf(needle) >= 0;
}

function withinRange_(r, from, to) {
  if (!from && !to) return true;
  const d = r.orderDate || r.arrivalDate || '';
  if (from && d < from) return false;
  if (to && d > to) return false;
  return true;
}

function loadOrdersCached_() {
  const cache = CacheService.getScriptCache();
  const cached = cache.get(SEARCH_CACHE_KEY_ORDERS);
  if (cached) {
    try { return JSON.parse(cached); } catch (e) { /* fallthrough */ }
  }
  const rows = readOrdersForSearch_();
  try {
    const json = JSON.stringify(rows);
    if (json.length < 95000) cache.put(SEARCH_CACHE_KEY_ORDERS, json, SEARCH_CACHE_TTL);
  } catch (e) { /* 100KB超はキャッシュしない */ }
  return rows;
}

function invalidateSearchCache_() {
  CacheService.getScriptCache().remove(SEARCH_CACHE_KEY_ORDERS);
  clearQueryCache_();
}

function readOrdersForSearch_() {
  const sh = getOrdersSheet_();
  if (!sh || sh.getLastRow() < 2) return [];
  const data = sh.getDataRange().getValues();
  const col = headerIndex_(data[0]);
  const out = [];
  for (let i = 1; i < data.length; i++) {
    const row = data[i];
    out.push({
      source: 'orders',
      orderNumber: String(row[col.orderNumber] || ''),
      lineNumber: row[col.lineNumber],
      orderDate: formatCellDate_(row[col.orderDate]),
      supplier: row[col.supplier],
      deliveryDate: row[col.deliveryDate],
      person: row[col.person],
      name: row[col.name],
      quantity: row[col.quantity],
      note: row[col.note],
      usage: row[col.usage],
      internalMemo: row[col.internalMemo],
      plannedDelivery: formatCellDate_(row[col.plannedDelivery]),
      arrivalDate: formatCellDate_(row[col.arrivalDate]),
      finishDate: formatCellDate_(row[col.finishDate]),
      status: row[col.status]
    });
  }
  return out;
}

function readLegacyForSearch_() {
  const sh = getLegacySheet_();
  if (!sh || sh.getLastRow() < 2) return [];
  const data = sh.getDataRange().getValues();
  const header = data[0];
  const idx = {
    company: header.indexOf('会社名'),
    name: header.indexOf('品名'),
    quantity: header.indexOf('数量'),
    arrival: header.indexOf('入荷日'),
    finish: header.indexOf('仕上日'),
    note: header.indexOf('備考')
  };
  const out = [];
  for (let i = 1; i < data.length; i++) {
    const row = data[i];
    out.push({
      source: 'legacy',
      orderNumber: '',
      supplier: row[idx.company],
      name: row[idx.name],
      quantity: row[idx.quantity],
      note: row[idx.note],
      arrivalDate: formatCellDate_(row[idx.arrival]),
      finishDate: formatCellDate_(row[idx.finish]),
