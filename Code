function appendAuditLog_(action, orderNumber, lineNumber, field, oldValue, newValue, note) {
  const sh = getAuditLogSheet_();
  if (!sh) return;
  let user = '';
  try { user = Session.getActiveUser().getEmail() || ''; } catch (e) { user = ''; }
  sh.appendRow([
    new Date(), user, action,
    orderNumber || '', lineNumber || '',
    field || '',
    oldValue == null ? '' : String(oldValue),
    newValue == null ? '' : String(newValue),
    note || ''
  ]);
}

function readSuppliers_() {
